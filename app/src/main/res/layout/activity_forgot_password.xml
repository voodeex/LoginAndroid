<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1238"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="100dp"
        android:paddingBottom="40dp">

        <TextView
            style="@style/TextStyle.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Забыли пароль?" />

        <TextView
            style="@style/TextStyle.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Введите логин и новый пароль" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            app:cardBackgroundColor="#1A1E40"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    style="@style/TextStyle.InputLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Логин" />

                <EditText
                    style="@style/Widget.Login.EditText"
                    android:id="@+id/etLogin"
                    android:hint="Введите логин"
                    android:inputType="text" />

                <TextView
                    style="@style/TextStyle.InputLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Новый пароль" />

                <EditText
                    style="@style/Widget.Login.EditText"
                    android:id="@+id/etNewPassword"
                    android:hint="Введите новый пароль"
                    android:inputType="textPassword" />

                <Button
                    style="@style/Widget.Login.Button"
                    android:id="@+id/btnChange"
                    android:text="Изменить пароль" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            style="@style/TextStyle.ForgotPassword"
            android:id="@+id/tvGoLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Вернуться к входу" />

    </LinearLayout>
</ScrollView>
