<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Login" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="TextStyle" parent="" />

    <style name="TextStyle.Title" parent="TextStyle">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextStyle.Subtitle" parent="TextStyle">
        <item name="android:textColor">#AAAACC</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>
    <style name="TextStyle.InputLabel" parent="TextStyle">
        <item name="android:textColor">#AAAACC</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="TextStyle.ForgotPassword" parent="TextStyle">
        <item name="android:textColor">#5B6BF5</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">end</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <style name="Widget.Login" parent="" />

    <style name="Widget.Login.EditText" parent="Widget.Login">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/input_background</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorHint">#6B6D9A</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:singleLine">true</item>
    </style>
    <style name="Widget.Login.Button" parent="Widget.Login">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:background">@drawable/button_gradient</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Theme.Login" parent="Base.Theme.Login" />
</resources>
